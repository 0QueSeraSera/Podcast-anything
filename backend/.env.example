# API Keys
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Application
DEBUG=false

# CORS
# Set to true only for local/dev convenience.
CORS_ALLOW_ALL=false
# Comma-separated list of explicit origins for non-dev mode.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Paths (optional, defaults shown)
TEMP_DIR=/tmp/podcast-anything
AUDIO_OUTPUT_DIR=/tmp/podcast-anything/audio

# TTS Settings (optional, defaults shown)
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry
TTS_CHUNK_SIZE=500

# Redis (optional, for Celery)
REDIS_URL=redis://localhost:6379/0
